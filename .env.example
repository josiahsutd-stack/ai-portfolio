APP_ENV=local
LOG_LEVEL=INFO

AI_PROVIDER=mock
VLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock

# Optional LLM/VLM provider settings.
# The portfolio works without these values by using local mock providers.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Keep local demos lightweight by default.
QUICK_MODE=true
